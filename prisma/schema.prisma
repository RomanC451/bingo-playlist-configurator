generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum TeamRole {
  OWNER
  ADMIN
  MEMBER
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  passwordHash  String?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts              Account[]
  sessions              Session[]
  bingoSessions         BingoSession[]
  teamMembers           TeamMember[]
  clipProposalVersions  ClipProposalVersion[]
  clipProposalVersionReactions ClipProposalVersionReaction[]
  sessionActivity       SessionUserActivity[]
  tracksFlaggedForAttention TrackClip[] @relation("TrackNeedsAttentionBy")
  tracksMarkedPerfect     TrackClip[] @relation("TrackMarkedPerfectBy")
  activeTeamId          String?
  activeTeam            Team?   @relation("UserActiveTeam", fields: [activeTeamId], references: [id], onDelete: SetNull)
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}

model SpotifyConnection {
  id            String   @id @default(cuid())
  teamId        String   @unique
  spotifyUserId String
  accessToken   String   @db.Text
  refreshToken  String   @db.Text
  expiresAt     DateTime
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
}

model Team {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members           TeamMember[]
  bingoSessions     BingoSession[]
  activeForUsers    User[]              @relation("UserActiveTeam")
  spotifyConnection SpotifyConnection?
}

model TeamMember {
  id        String   @id @default(cuid())
  teamId    String
  userId    String
  role      TeamRole @default(MEMBER)
  createdAt DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([userId])
}

model BingoSession {
  id                    String   @id @default(cuid())
  userId                String
  teamId                String?
  name                  String
  spotifyPlaylistId     String
  spotifyPlaylistName   String?
  spotifyPlaylistImageUrl String?
  defaultClipDurationMs Int      @default(30000)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  team       Team?       @relation(fields: [teamId], references: [id], onDelete: Cascade)
  trackClips TrackClip[]
  userActivity SessionUserActivity[]

  @@index([userId])
  @@index([teamId])
}

model SessionUserActivity {
  userId       String
  sessionId    String
  lastWorkedAt DateTime @default(now()) @updatedAt

  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  session BingoSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@id([userId, sessionId])
  @@index([userId, lastWorkedAt])
}

model TrackClip {
  id             String @id @default(cuid())
  sessionId      String
  spotifyTrackId String
  trackName      String
  artistName     String
  albumArtUrl    String?
  durationMs     Int    @default(0)
  position       Int
  startMs        Int    @default(0)
  endMs          Int    @default(30000)
  needsAttention         Boolean @default(false)
  needsAttentionByUserId String?
  needsAttentionComment  String?
  markedPerfect          Boolean @default(false)
  markedPerfectByUserId  String?

  session            BingoSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  needsAttentionBy   User?         @relation("TrackNeedsAttentionBy", fields: [needsAttentionByUserId], references: [id], onDelete: SetNull)
  markedPerfectBy    User?         @relation("TrackMarkedPerfectBy", fields: [markedPerfectByUserId], references: [id], onDelete: SetNull)
  proposal           ClipProposal?

  @@unique([sessionId, spotifyTrackId])
  @@index([sessionId, position])
}

model TrackWaveform {
  spotifyTrackId String   @id
  durationMs     Int
  peaks          Json
  source         String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model ClipProposal {
  id          String   @id @default(cuid())
  trackClipId String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  trackClip TrackClip             @relation(fields: [trackClipId], references: [id], onDelete: Cascade)
  versions  ClipProposalVersion[]
}

model ClipProposalVersion {
  id              String   @id @default(cuid())
  proposalId      String
  startMs         Int
  endMs           Int
  createdByUserId String
  createdAt       DateTime @default(now())

  proposal  ClipProposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  createdBy User         @relation(fields: [createdByUserId], references: [id], onDelete: Cascade)
  reactions ClipProposalVersionReaction[]

  @@index([proposalId, createdAt])
  @@index([createdByUserId])
}

enum ClipReactionType {
  LIKE
  DISLIKE
}

model ClipProposalVersionReaction {
  versionId String
  userId    String
  reaction  ClipReactionType
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  version ClipProposalVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  user    User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([versionId, userId])
  @@index([versionId])
  @@index([userId])
}
